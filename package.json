{
  "name": "thedailyhaiku",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node -e \"const{execSync}=require('child_process');try{execSync('npx drizzle-kit migrate',{stdio:'inherit'})}catch(e){console.error('DB migrate failed:',e.message)};try{execSync('npx tsx src/seed.ts',{stdio:'inherit'})}catch(e){console.error('Seed failed:',e.message)};execSync('next start',{stdio:'inherit'})\"",
    "lint": "eslint",
    "db:generate": "npx drizzle-kit generate",
    "db:migrate": "npx drizzle-kit migrate",
    "db:seed": "npx tsx src/seed.ts",
    "setup": "npx drizzle-kit migrate && npx tsx src/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/instrument-serif": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/karla": "^5.2.8",
    "@fontsource/young-serif": "^5.2.7",
    "@libsql/client": "^0.17.3",
    "bcryptjs": "^3.0.3",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "iron-session": "^8.0.4",
    "next": "^15.5.19",
    "pg": "^8.21.0",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "resend": "^6.12.4",
    "syllable": "^5.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9",
    "eslint-config-next": "^15.5.19",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
