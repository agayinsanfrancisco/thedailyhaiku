# Copy to .env.local and fill in. .env.local is gitignored.

# Postgres connection. Local dev options:
#   - Homebrew:  postgres://<your-mac-username>@localhost:5432/thedailyhaiku
#   - Docker (compose.yaml):  postgres://postgres:postgres@localhost:5432/thedailyhaiku
# Production uses the Coolify-injected internal Postgres URL.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/thedailyhaiku

# Admin panel (gated at /nimda behind ADMIN_KEY, then this password).
ADMIN_PASSWORD=change-me
SESSION_SECRET=at-least-32-characters-long-random-string-here
ADMIN_KEY=a-long-random-hex-string

# Optional. Email (Resend) — no-op until set.
# RESEND_API_KEY=
# EMAIL_FROM=the daily haiku <hello@thedailyhaiku.com>

# Optional. Claude API for event validation/generation.
# ANTHROPIC_API_KEY=
